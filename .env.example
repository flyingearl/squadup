APP_NAME=SquadUp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (Postgres via Docker Compose) ------------------------------
# Host 'postgres' is the compose service name; containers reach each other by DNS.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=squadup
DB_USERNAME=squadup
DB_PASSWORD=squadup

# --- Session / Queue / Cache (Redis) -------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=redis
CACHE_STORE=redis

BROADCAST_CONNECTION=reverb

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Reverb (Laravel's native websocket server) --------------------------
# Two perspectives in play:
#   1. App PHP -> Reverb server (server-to-server, inside Docker network).
#      Uses REVERB_HOST=reverb (compose service name) on port 8080.
#   2. Browser -> Reverb server (from host, via Docker port map 8082:8080).
#      Uses VITE_REVERB_HOST=localhost on port 8082.
REVERB_APP_ID=squadup
REVERB_APP_KEY=squadup-app-key
REVERB_APP_SECRET=squadup-app-secret

REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8082
VITE_REVERB_SCHEME=http

# --- Filesystem (MinIO via the S3 driver) --------------------------------
# MinIO is S3-compatible, so Laravel's 's3' driver works unchanged in prod.
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=squadup
AWS_SECRET_ACCESS_KEY=squadup-secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=squadup
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/squadup
AWS_USE_PATH_STYLE_ENDPOINT=true

MINIO_ROOT_USER=squadup
MINIO_ROOT_PASSWORD=squadup-secret

# --- Mail (Mailpit — catches outbound mail, view at http://localhost:8025)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@squadup.test"
MAIL_FROM_NAME="${APP_NAME}"

MEMCACHED_HOST=127.0.0.1

VITE_APP_NAME="${APP_NAME}"
