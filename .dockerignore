# Keep the build context small and reproducible.
# In dev we bind-mount the project, so this mainly speeds up `docker build`.

.git
.gitignore
.gitattributes

# Local env files — never baked into images.
.env
.env.*
!.env.example

# Installed deps — installed inside the container instead.
node_modules
vendor

# Build output — regenerated inside container / by Vite.
public/build
public/hot

# Laravel writeable paths — container creates fresh.
storage/logs/*
!storage/logs/.gitignore
storage/framework/cache/data/*
!storage/framework/cache/data/.gitignore
storage/framework/sessions/*
!storage/framework/sessions/.gitignore
storage/framework/testing/*
!storage/framework/testing/.gitignore
storage/framework/views/*
!storage/framework/views/.gitignore
storage/app/livewire-tmp/*
!storage/app/livewire-tmp/.gitkeep

# Claudify / planning artefacts — not part of the app.
.claude
briefs
openspec
Daily Notes
Task Board.md
Scratchpad.md
CLAUDE.local.md

# Editor / OS cruft.
.vscode
.idea
.DS_Store
*.log
*.swp
